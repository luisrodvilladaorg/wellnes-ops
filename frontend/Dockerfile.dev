# Official and stable Nginx image (widely used in production)
FROM nginx:stable-alpine

# Remove default configuration
RUN rm -rf /usr/share/nginx/html/*

# Copy static website to Nginx served directory
COPY mi-web/ /usr/share/nginx/html/

# Expose internal port 80 (standard Nginx)
EXPOSE 80

# Healthcheck to verify Nginx responsiveness
HEALTHCHECK --interval=10s --timeout=3s --retries=3 \
    CMD wget -qO- http://localhost || exit 1

# Start Nginx in foreground
CMD ["nginx", "-g", "daemon off;"]
